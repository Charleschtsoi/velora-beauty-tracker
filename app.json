{
  "expo": {
    "name": "Velora",
    "slug": "velora",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "src/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.velora.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.velora.app"
    },
    "web": {},
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
